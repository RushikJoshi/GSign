PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
APP_BASE_URL=http://localhost:5173

MONGO_URI=mongodb://127.0.0.1:27017
# Atlas example:
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/?retryWrites=true&w=majority&appName=<app-name>
MONGO_DB_NAME=gitakshmi_sign
DNS_SERVERS=8.8.8.8,1.1.1.1

JWT_ACCESS_SECRET=replace_with_secure_access_secret
JWT_REFRESH_SECRET=replace_with_secure_refresh_secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

MAIL_FROM=no-reply@gitakshmisign.local
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
